{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "regions": ["iad1"],
  "functions": {
    "app/api/cron/snapshot/route.ts": {
      "maxDuration": 60
    },
    "app/api/trading-bot/backtest/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "0 22 * * *"
    }
  ]
}
