# Copy this file to .env.local and fill in the keys you have.
# Any missing/blank keys simply fall back to mock data for that widget —
# nothing crashes if you leave this file untouched.

# Optional. CoinGecko's free "Demo" plan key (https://www.coingecko.com/en/developers/dashboard).
# The crypto-prices route works without it too, just more likely to get rate-limited.
COINGECKO_API_KEY=

# Bybit broker/affiliate-program API key. NOTE: a normal trading API key will
# NOT work here — see the comment in lib/exchanges/bybit.ts for details.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bitget affiliate API key (needs the "affiliate" permission ticked when created).
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

# MEXC API key (regular spot key works for /api/v3/account; the affiliate
# commission endpoint requires your account to actually be a MEXC affiliate).
# NOTE: MEXC's Grid Bot feature has no public API, so the GRID BOT widget
# stays mock regardless of these keys — see lib/exchanges/mexc.ts.
MEXC_API_KEY=
MEXC_API_SECRET=

# Optional. If set, TradingView alert webhooks must include this as
# ?secret=... in the URL or they get rejected with 401. Leave blank while
# testing locally (see app/api/tradingview-webhook/route.ts for setup notes).
TRADINGVIEW_WEBHOOK_SECRET=
