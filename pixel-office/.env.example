# ─────────────────────────────────────────────────────────────────────────────
# Database — Neon PostgreSQL + Prisma (Portfolio Management module)
# Copy to `.env` (gitignored) and fill in real values. Never commit real creds.
#
# Prisma needs TWO connection strings for Neon:
#   DATABASE_URL — POOLED (Neon pgBouncer). Used by the app at runtime. The
#                  serverless/dashboard-poll workload opens many short-lived
#                  connections; the pooler keeps Neon from exhausting them.
#   DIRECT_URL   — UNPOOLED (direct 5432). Used ONLY by `prisma migrate` /
#                  `prisma db push` / introspection. Migrations cannot run
#                  through pgBouncer.
#
# Get both from the Neon dashboard → Connection Details. The pooled host
# contains "-pooler"; the direct host does not.
# ─────────────────────────────────────────────────────────────────────────────

# Pooled — note the "-pooler" host and sslmode=require. pgbouncer=true tells
# Prisma this is a pooled connection.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"

# Unpooled/direct — same DB, host WITHOUT "-pooler". Migrations use this.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# For local dev against Docker/local Postgres instead of Neon, both can point at
# the same direct URL (no pooler locally), e.g.:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pixeloffice?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pixeloffice?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# Auth — Clerk (external identity; the app stores NO passwords). Without these the
# app still builds/runs, and every /api/portfolios/* route returns 401.
# https://dashboard.clerk.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Optional Clerk URL overrides — the app does NOT reference these in code (Clerk uses
# its hosted defaults). Set ONLY if you add custom sign-in/up pages.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ─────────────────────────────────────────────────────────────────────────────
# Cron auth — shared secret for the DAILY snapshot job (Vercel Cron).
# Vercel automatically sends this as `Authorization: Bearer <CRON_SECRET>` to the
# cron path in vercel.json. The capture-all endpoint must verify it.
# ⚠️ CHANGE REQUEST: the target route /api/cron/snapshot does NOT exist yet — see
# docs/deployment.md. Generate a strong value, e.g. `openssl rand -hex 32`.
# Production-required (validated by scripts/check-env.mjs / lib/env.ts).
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# Market data providers (all OPTIONAL — missing keys degrade gracefully to cached
# PriceSnapshots then mock, and the API reports source:"partial"/"mock").
# ─────────────────────────────────────────────────────────────────────────────
# US stocks/ETFs (VOO/QQQM/SCHD/O) — https://finnhub.io/dashboard
FINNHUB_API_KEY=""
# CoinGecko free "Demo" key (optional; raises rate limits) — https://docs.coingecko.com
COINGECKO_API_KEY=""
# FX (USD/THB) uses open.er-api.com which needs no key.

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting (optional) — per-user, in-memory (CR-003 F-02). All have sane
# defaults; leave unset unless you need to tune them. See lib/api/rate-limit.ts.
# NOTE: the default limiter counts per serverless instance, so the effective
# global limit scales with concurrent instances (best-effort, not a hard cap).
# ─────────────────────────────────────────────────────────────────────────────
# Set to "1" to disable rate limiting entirely (any other value = enabled).
RATE_LIMIT_DISABLED="0"
# Window length in milliseconds for the fixed-window counter (default 60000 = 60s).
RATE_LIMIT_WINDOW_MS="60000"
# Max "write" requests allowed per user per window (default 30).
RATE_LIMIT_WRITE_MAX="30"
# Max provider-hitting "read" requests allowed per user per window (default 60).
RATE_LIMIT_READ_MAX="60"
# Max /api/agents roster reads allowed per user per window (default 30).
RATE_LIMIT_AGENTS_MAX="30"
# Max /api/trading-bot/{account,positions} reads per user per window (default 60).
RATE_LIMIT_TRADING_BOT_READ_MAX="60"
# Max /api/trading-bot/{orders,positions/close} writes per user per window (default 20).
RATE_LIMIT_TRADING_BOT_WRITE_MAX="20"

# ─────────────────────────────────────────────────────────────────────────────
# Agents roster cache (optional) — in-process TTL cache in front of loadAgents()
# for /api/agents. Default is sane; leave unset unless tuning. See
# lib/agents/agents-cache.ts.
# ─────────────────────────────────────────────────────────────────────────────
# Time-to-live in milliseconds for the cached roster payload (default 30000 = 30s).
AGENTS_CACHE_TTL_MS="30000"
